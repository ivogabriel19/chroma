---
interface Props {
  title?: string;
}
const { title = 'Paletas' } = Astro.props;
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>

        <!-- Inline crítico: evita FOUC bloqueando el render hasta tener bg y tokens -->
    <style>
      :root {
        --bg:         #fafafa;
        --bg-2:       #f0f0f0;
        --bg-3:       #e5e5e5;
        --border:     #dcdcdc;
        --border-2:   #c8c8c8;
        --text:       #323031;
        --text-2:     #6b6869;
        --text-3:     #a8a6a7;
        --accent:     #FFEE8C;
        --accent-dim: #f0dc60;
        --accent-2:   #547AA5;
        --danger:     #c0392b;
        --radius:     10px;
        --radius-lg:  16px;
      }
      html, body {
        background: #fafafa;
        color: #323031;
        margin: 0;
      }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>