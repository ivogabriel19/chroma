---
import BaseLayout from './BaseLayout.astro';
import { getSessionFromCookies } from '../lib/supabase';

interface Props {
  title?: string;
}
const { title = 'Paletas' } = Astro.props;

const cookieHeader = Astro.request.headers.get('cookie') ?? '';
const cookies = Object.fromEntries(
  cookieHeader.split(';').map(c => {
    const [k, ...v] = c.trim().split('=');
    return [k, v.join('=')];
  })
);

const session = await getSessionFromCookies(cookies);
if (!session) return Astro.redirect('/login');
const user = session.user;
---
<BaseLayout title={title}>
  <div class="app-shell">
    <header class="app-header">
      <a href="/dashboard" class="logo">
        <span class="logo-mark">◈</span>
        <span class="logo-text">Paletta</span>
      </a>
      <nav class="header-nav">
        <a href="/dashboard" class="btn-new">
          Dashboard
        </a>
        <a href="/explore" class="btn-new">
          <span>🔎</span>Explore
        </a>
        <div class="user-menu">
          <span class="user-email">{user.email}</span>
          <form method="POST" action="/api/auth/logout">
            <button type="submit" class="btn-logout">Salir</button>
          </form>
        </div>
      </nav>
    </header>

    <main class="app-main">
      <slot />
    </main>
  </div>
</BaseLayout>

<style>
  .app-shell {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  .app-header {
    position: sticky;
    top: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 2rem;
    height: 56px;
    background: rgba(14,14,17,0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    color: var(--text);
  }
  .logo-mark {
    font-size: 1.3rem;
    color: var(--accent);
    line-height: 1;
  }
  .logo-text {
    font-size: 1.1rem;
    font-weight: 800;
    letter-spacing: -0.03em;
  }

  .header-nav {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .btn-new {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.45rem 1rem;
    background: var(--accent);
    color: #0e0e11;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.85rem;
    border-radius: 8px;
    text-decoration: none;
    transition: background 0.15s, transform 0.1s;
  }
  .btn-new:hover {
    background: var(--accent-dim);
    transform: translateY(-1px);
  }
  .btn-new span { font-size: 1.1rem; line-height: 1; }

  .user-menu {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .user-email {
    font-size: 0.8rem;
    color: var(--text-3);
    font-family: var(--font-mono);
    display: none;
  }
  @media (min-width: 640px) { .user-email { display: block; } }

  .btn-logout {
    background: none;
    border: 1px solid var(--border-2);
    color: var(--text-2);
    padding: 0.4rem 0.85rem;
    border-radius: 7px;
    font-family: var(--font-display);
    font-size: 0.82rem;
    cursor: pointer;
    transition: border-color 0.15s, color 0.15s;
  }
  .btn-logout:hover {
    border-color: var(--danger);
    color: var(--danger);
  }

  .app-main {
    flex: 1;
    max-width: 1200px;
    width: 100%;
    margin: 0 auto;
    padding: 2.5rem 2rem;
  }
</style>