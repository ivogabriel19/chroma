---
import AppLayout from '../../../layouts/AppLayout.astro';
import { getSessionFromCookies } from '../../../lib/supabase';
import { getPaletteById } from '../../../lib/palettes';

const cookieHeader = Astro.request.headers.get('cookie') ?? '';
const cookieMap = Object.fromEntries(
  cookieHeader.split(';').map(c => {
    const [k, ...v] = c.trim().split('=');
    return [k, v.join('=')];
  })
);
const session = await getSessionFromCookies(cookieMap);
if (!session) return Astro.redirect('/login');

const { id } = Astro.params;
const palette = await getPaletteById(id!);
if (!palette || palette.user_id !== session.user.id) return Astro.redirect('/dashboard');

const colors = (palette.colors ?? []).sort((a, b) => a.position - b.position);
---

<AppLayout title={palette.name}>
  <div class="detail-page">
    <div class="detail-header">
      <a href="/dashboard" class="back-link">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
          <path d="M10 12L6 8l4-4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Volver
      </a>
      <div>
        <h1>{palette.name}</h1>
        <p class="meta">
          <span>{colors.length} color{colors.length !== 1 ? 'es' : ''}</span>
          <span class="dot">·</span>
          <span>{new Date(palette.created_at).toLocaleDateString('es-AR', { day:'numeric', month:'long', year:'numeric' })}</span>
        </p>
      </div>
    </div>

    <!-- Vista pantalla completa estilo Coolors -->
    <div class="fullscreen-palette">
      {colors.map(c => (
        <div class="color-col" style={`background:${c.hex}`} data-hex={c.hex}>
          <div class="color-overlay">
            <span class="color-name-display">{c.name ?? ''}</span>
            <span class="color-hex-display">{c.hex.toUpperCase()}</span>
            <button class="btn-copy-full" data-hex={c.hex}>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                <rect x="9" y="9" width="13" height="13" rx="2" stroke="currentColor" stroke-width="2"/>
                <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1" stroke="currentColor" stroke-width="2"/>
              </svg>
              <span>Copiar</span>
            </button>
          </div>
        </div>
      ))}
    </div>

    <!-- Lista detallada -->
    <div class="colors-list">
      {colors.map(c => (
        <div class="color-row">
          <div class="color-dot" style={`background:${c.hex}`} />
          <div class="color-details">
            <span class="hex-tag">{c.hex.toUpperCase()}</span>
            {c.name && <span class="name-tag">{c.name}</span>}
          </div>
          <button class="btn-copy-small" data-hex={c.hex}>Copiar HEX</button>
        </div>
      ))}
    </div>
  </div>
</AppLayout>

<script>
  document.querySelectorAll('[data-hex]').forEach(el => {
    const btn = el.classList.contains('btn-copy-full') || el.classList.contains('btn-copy-small')
      ? el : null;
    if (!btn) return;

    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const hex = (btn as HTMLElement).dataset.hex ?? '';
      navigator.clipboard.writeText(hex);

      const span = btn.querySelector('span') ?? btn;
      const original = span.textContent;
      span.textContent = '✓ Copiado';
      setTimeout(() => span.textContent = original, 1500);
    });
  });
</script>

<style>
  .detail-page { display: flex; flex-direction: column; gap: 2.5rem; }

  .detail-header { display: flex; flex-direction: column; gap: 0.75rem; }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    color: var(--text-3);
    text-decoration: none;
    font-size: 0.85rem;
    transition: color 0.15s;
    width: fit-content;
  }
  .back-link:hover { color: var(--text); }

  h1 {
    font-size: 2rem;
    font-weight: 800;
    letter-spacing: -0.04em;
  }
  .meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-3);
    font-family: var(--font-mono);
    font-size: 0.8rem;
  }
  .dot { color: var(--border-2); }

  /* Fullscreen palette viewer */
  .fullscreen-palette {
    display: flex;
    height: 320px;
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--border);
  }

  .color-col {
    flex: 1;
    position: relative;
    transition: flex 0.3s ease;
    cursor: default;
  }
  .color-col:hover { flex: 1.8; }

  .color-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 1.25rem 1rem;
    background: linear-gradient(to top, rgba(0,0,0,0.55), transparent);
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    opacity: 0;
    transition: opacity 0.2s;
  }
  .color-col:hover .color-overlay { opacity: 1; }

  .color-name-display {
    font-size: 0.7rem;
    color: rgba(255,255,255,0.7);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .color-hex-display {
    font-family: var(--font-mono);
    font-weight: 500;
    font-size: 0.95rem;
    color: white;
  }
  .btn-copy-full {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    margin-top: 0.4rem;
    padding: 0.35rem 0.7rem;
    background: rgba(255,255,255,0.15);
    border: 1px solid rgba(255,255,255,0.25);
    border-radius: 6px;
    color: white;
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 600;
    cursor: pointer;
    backdrop-filter: blur(4px);
    transition: background 0.15s;
    width: fit-content;
  }
  .btn-copy-full:hover { background: rgba(255,255,255,0.25); }

  /* Lista */
  .colors-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .color-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.75rem 1rem;
    background: var(--bg-2);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    transition: border-color 0.15s;
  }
  .color-row:hover { border-color: var(--border-2); }

  .color-dot {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    flex-shrink: 0;
    border: 1px solid rgba(255,255,255,0.05);
  }
  .color-details {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex: 1;
  }
  .hex-tag {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    font-weight: 500;
  }
  .name-tag {
    font-size: 0.82rem;
    color: var(--text-3);
  }
  .btn-copy-small {
    padding: 0.35rem 0.75rem;
    background: var(--bg-3);
    border: 1px solid var(--border);
    border-radius: 6px;
    color: var(--text-2);
    font-family: var(--font-display);
    font-size: 0.78rem;
    cursor: pointer;
    transition: border-color 0.15s, color 0.15s;
    white-space: nowrap;
  }
  .btn-copy-small:hover {
    border-color: var(--accent);
    color: var(--accent);
  }
</style>