---
import AppLayout from '../../../layouts/AppLayout.astro';
import { getSessionFromCookies } from '../../../lib/supabase';
import { getPaletteById } from '../../../lib/palettes';

const cookieHeader = Astro.request.headers.get('cookie') ?? '';
const cookieMap = Object.fromEntries(
  cookieHeader.split(';').map(c => {
    const [k, ...v] = c.trim().split('=');
    return [k, v.join('=')];
  })
);
const session = await getSessionFromCookies(cookieMap);
if (!session) return Astro.redirect('/login');

const { id } = Astro.params;
const palette = await getPaletteById(id!);
if (!palette || palette.user_id !== session.user.id) return Astro.redirect('/dashboard');

const colors = (palette.colors ?? []).sort((a, b) => a.position - b.position);
---

<AppLayout title={palette.name}>
  <div class="detail-page">
    <div class="detail-header">
      <a href="/dashboard" class="back-link">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
          <path d="M10 12L6 8l4-4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Volver
      </a>
      <div>
        <h1>{palette.name}</h1>
        <p class="meta">
          <span>{colors.length} color{colors.length !== 1 ? 'es' : ''}</span>
          <span class="dot">·</span>
          <span>{new Date(palette.created_at).toLocaleDateString('es-AR', { day:'numeric', month:'long', year:'numeric' })}</span>
        </p>
      </div>
    </div>

    <!-- Vista pantalla completa estilo Coolors -->
    <div class="fullscreen-palette">
      {colors.map(c => (
        <div class="color-col" style={`background:${c.hex}`} data-hex={c.hex} data-color-id={c.id}>
          <div class="color-overlay">
            <span class="color-name-display">{c.name ?? ''}</span>
            <span class="color-hex-display">{c.hex.toUpperCase()}</span>
            <button class="btn-copy-full" data-hex={c.hex}>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                <rect x="9" y="9" width="13" height="13" rx="2" stroke="currentColor" stroke-width="2"/>
                <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1" stroke="currentColor" stroke-width="2"/>
              </svg>
              <span>Copiar</span>
            </button>
          </div>
        </div>
      ))}
    </div>

    <!-- Lista detallada -->
    <div class="colors-list">
      {colors.map(c => (
        <div class="color-row" data-color-id={c.id} data-palette-id={palette.id}>
          <div class="color-dot" style={`background:${c.hex}`} data-hex={c.hex} title="Ver variantes" />
          <div class="color-details">
            <span class="hex-tag">{c.hex.toUpperCase()}</span>
            <span class="name-tag">{c.name ?? ''}</span>
          </div>
          <button class="btn-edit-color" title="Editar color">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
              <path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <input type="color" class="color-edit-picker" value={c.hex} />
          <button class="btn-copy-small" data-hex={c.hex}>Copiar HEX</button>
          <div class="variants-strip hidden"></div>
        </div>
      ))}
    </div>
  </div>
</AppLayout>

<script>
  import { getColorName, hexToHsl, hslToHex } from '../../../lib/colors';

  // Botones de copiar
  document.querySelectorAll('[data-hex]').forEach(el => {
    const btn = el.classList.contains('btn-copy-full') || el.classList.contains('btn-copy-small')
      ? el : null;
    if (!btn) return;

    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const hex = (btn as HTMLElement).dataset.hex ?? '';
      navigator.clipboard.writeText(hex);

      const span = btn.querySelector('span') ?? btn;
      const original = span.textContent;
      span.textContent = '✓ Copiado';
      setTimeout(() => span.textContent = original, 1500);
    });
  });

  // Edición de colores
  document.querySelectorAll<HTMLElement>('.color-row').forEach(row => {
    const colorId = row.dataset.colorId!;
    const paletteId = row.dataset.paletteId!;
    const dot = row.querySelector<HTMLElement>('.color-dot')!;
    const hexTag = row.querySelector<HTMLElement>('.hex-tag')!;
    const nameTag = row.querySelector<HTMLElement>('.name-tag')!;
    const editBtn = row.querySelector<HTMLButtonElement>('.btn-edit-color')!;
    const picker = row.querySelector<HTMLInputElement>('.color-edit-picker')!;
    const copyBtn = row.querySelector<HTMLButtonElement>('.btn-copy-small')!;

    const fullCol = document.querySelector<HTMLElement>(`.fullscreen-palette [data-color-id="${colorId}"]`);
    const fullHexDisplay = fullCol?.querySelector<HTMLElement>('.color-hex-display') ?? null;
    const fullNameDisplay = fullCol?.querySelector<HTMLElement>('.color-name-display') ?? null;
    const fullCopyBtn = fullCol?.querySelector<HTMLElement>('.btn-copy-full') ?? null;

    editBtn.addEventListener('click', () => picker.click());

    // Preview en vivo
    picker.addEventListener('input', () => {
      const hex = picker.value;
      dot.style.background = hex;
      if (fullCol) fullCol.style.background = hex;
    });

    // Función compartida: aplicar un nuevo hex y persistir
    async function applyNewColor(hex: string) {
      dot.style.background = hex;
      dot.dataset.hex = hex;
      hexTag.textContent = hex.toUpperCase();
      copyBtn.dataset.hex = hex;
      picker.value = hex;
      if (fullCol) fullCol.style.background = hex;
      if (fullHexDisplay) fullHexDisplay.textContent = hex.toUpperCase();
      if (fullCopyBtn) fullCopyBtn.dataset.hex = hex;
      nameTag.textContent = '…';

      const name = await getColorName(hex).catch(() => '');
      nameTag.textContent = name;
      if (fullNameDisplay) fullNameDisplay.textContent = name;

      await fetch('/api/palettes/update-color', {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ colorId, paletteId, hex, name }),
      }).catch(() => {});
    }

    // Commit al cerrar el picker libre
    picker.addEventListener('change', () => applyNewColor(picker.value));

    // Variantes: click en el dot
    const variantsStrip = row.querySelector<HTMLElement>('.variants-strip')!;
    const VARIANT_LIGHTNESSES = [10, 20, 30, 40, 50, 60, 70, 80, 90];

    dot.addEventListener('click', () => {
      if (!variantsStrip.classList.contains('hidden')) {
        variantsStrip.classList.add('hidden');
        return;
      }

      const currentHex = hexTag.textContent?.trim() ?? '#000000';
      const hsl = hexToHsl(currentHex);
      const closestL = VARIANT_LIGHTNESSES.reduce((a, b) =>
        Math.abs(a - hsl.l) <= Math.abs(b - hsl.l) ? a : b
      );

      variantsStrip.innerHTML = '';
      variantsStrip.classList.remove('hidden');

      VARIANT_LIGHTNESSES.forEach(l => {
        const hex = hslToHex({ h: hsl.h, s: hsl.s, l });
        const btn = document.createElement('button');
        btn.className = 'variant-swatch' + (l === closestL ? ' active' : '');
        btn.style.background = hex;
        btn.title = hex.toUpperCase();

        btn.addEventListener('click', async () => {
          variantsStrip.querySelectorAll('.variant-swatch').forEach(s => s.classList.remove('active'));
          btn.classList.add('active');
          await applyNewColor(hex);
          // Re-calcular closest para reflejar el nuevo color seleccionado
          variantsStrip.querySelectorAll('.variant-swatch').forEach(s => s.classList.remove('active'));
          btn.classList.add('active');
        });

        variantsStrip.appendChild(btn);
      });
    });
  });
</script>

<style>
  .detail-page { display: flex; flex-direction: column; gap: 2.5rem; }

  .detail-header { display: flex; flex-direction: column; gap: 0.75rem; }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    color: var(--text-3);
    text-decoration: none;
    font-size: 0.85rem;
    transition: color 0.15s;
    width: fit-content;
  }
  .back-link:hover { color: var(--text); }

  h1 {
    font-size: 2rem;
    font-weight: 800;
    letter-spacing: -0.04em;
  }
  .meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-3);
    font-family: var(--font-mono);
    font-size: 0.8rem;
  }
  .dot { color: var(--border-2); }

  /* Fullscreen palette viewer */
  .fullscreen-palette {
    display: flex;
    height: 320px;
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--border);
  }

  .color-col {
    flex: 1;
    position: relative;
    transition: flex 0.3s ease;
    cursor: default;
  }
  .color-col:hover { flex: 1.8; }

  .color-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 1.25rem 1rem;
    background: linear-gradient(to top, rgba(0,0,0,0.55), transparent);
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    opacity: 0;
    transition: opacity 0.2s;
  }
  .color-col:hover .color-overlay { opacity: 1; }

  .color-name-display {
    font-size: 0.7rem;
    color: rgba(255,255,255,0.7);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .color-hex-display {
    font-family: var(--font-mono);
    font-weight: 500;
    font-size: 0.95rem;
    color: white;
  }
  .btn-copy-full {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    margin-top: 0.4rem;
    padding: 0.35rem 0.7rem;
    background: rgba(255,255,255,0.15);
    border: 1px solid rgba(255,255,255,0.25);
    border-radius: 6px;
    color: white;
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 600;
    cursor: pointer;
    backdrop-filter: blur(4px);
    transition: background 0.15s;
    width: fit-content;
  }
  .btn-copy-full:hover { background: rgba(255,255,255,0.25); }

  /* Lista */
  .colors-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .color-row {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
    padding: 0.75rem 1rem;
    background: var(--bg-2);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    transition: border-color 0.15s;
    position: relative;
  }
  .color-row:hover { border-color: var(--border-2); }

  .color-dot {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    flex-shrink: 0;
    border: 1px solid rgba(255,255,255,0.05);
    cursor: pointer;
    transition: transform 0.15s, box-shadow 0.15s;
  }
  .color-dot:hover {
    transform: scale(1.12);
    box-shadow: 0 2px 8px rgba(0,0,0,0.3);
  }
  .color-details {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex: 1;
  }
  .hex-tag {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    font-weight: 500;
  }
  .name-tag {
    font-size: 0.82rem;
    color: var(--text-3);
  }
  .btn-copy-small {
    padding: 0.35rem 0.75rem;
    background: var(--bg-3);
    border: 1px solid var(--border);
    border-radius: 6px;
    color: var(--text-2);
    font-family: var(--font-display);
    font-size: 0.78rem;
    cursor: pointer;
    transition: border-color 0.15s, color 0.15s;
    white-space: nowrap;
  }
  .btn-copy-small:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .btn-edit-color {
    padding: 0.35rem 0.5rem;
    background: var(--bg-3);
    border: 1px solid var(--border);
    border-radius: 6px;
    color: var(--text-3);
    cursor: pointer;
    display: flex;
    align-items: center;
    transition: border-color 0.15s, color 0.15s;
    flex-shrink: 0;
  }
  .btn-edit-color:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .color-edit-picker {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
    pointer-events: none;
  }

  .variants-strip {
    flex-basis: 100%;   /* ocupa toda la línea y fuerza el wrap */
    display: flex;
    gap: 0.45rem;
    flex-wrap: wrap;
    padding-top: 0.6rem;
    border-top: 1px solid var(--border);
    margin-top: -0.25rem; /* compensa el gap del row para que quede pegado */
  }
  .variants-strip.hidden { display: none; }

  /* Los swatches se crean con JS → necesitan :global() */
  :global(.variant-swatch) {
    width: 34px;
    height: 34px;
    border-radius: 7px;
    border: 2px solid transparent;
    cursor: pointer;
    transition: transform 0.15s, box-shadow 0.15s;
    flex-shrink: 0;
  }
  :global(.variant-swatch:hover) { transform: translateY(-3px); }
  :global(.variant-swatch.active) {
    border-color: white;
    box-shadow: 0 0 0 2px var(--accent);
  }
</style>