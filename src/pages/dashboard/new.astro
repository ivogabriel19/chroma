---
import AppLayout from "../../layouts/AppLayout.astro";
import { getSessionFromCookies } from "../../lib/supabase";

const cookieHeader = Astro.request.headers.get("cookie") ?? "";
const cookieMap = Object.fromEntries(
  cookieHeader.split(";").map((c) => {
    const [k, ...v] = c.trim().split("=");
    return [k, v.join("=")];
  }),
);
const session = await getSessionFromCookies(cookieMap);
if (!session) return Astro.redirect("/login");
---

<AppLayout title="Nueva paleta">
  <div class="generator-page">
    <div class="gen-header">
      <div>
        <a href="/dashboard" class="back-link">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path
              d="M10 12L6 8l4-4"
              stroke="currentColor"
              stroke-width="1.8"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
          Volver
        </a>
        <h1>Nueva paleta</h1>
      </div>
      <div class="spacebar-hint">
        <kbd>Espacio</kbd> para generar
      </div>
    </div>

    <!-- Controles -->
    <div class="controls-bar">
      <div class="control-group">
        <label for="harmony">Harmonía</label>
        <select id="harmony">
          <option value="analogous">Análogo</option>
          <option value="complementary">Complementario</option>
          <option value="triadic">Triádico</option>
          <option value="split-complementary">Split-compl.</option>
          <option value="tetradic">Tetrádico</option>
          <option value="monochromatic">Monocromático</option>
        </select>
      </div>

      <div class="control-group">
        <label>Color base</label>
        <div class="color-input-row">
          <input type="color" id="base-color-picker" value="#6366f1" />
          <input
            type="text"
            id="base-color-hex"
            value="#6366f1"
            maxlength="7"
          />
        </div>
      </div>

      <div class="control-group">
        <label for="count">Colores: <span id="count-label">5</span></label>
        <input type="range" id="count" min="3" max="8" value="5" />
      </div>

      <div class="controls-actions">
        <button id="btn-random" class="btn-secondary">🎲 Aleatorio</button>
        <button id="btn-from-base" class="btn-secondary">🎨 Desde base</button>
      </div>
    </div>

    <!-- Paleta fullscreen -->
    <div id="palette-view" class="palette-view">
      <div class="palette-placeholder">
        <span class="placeholder-icon">◈</span>
        <p>Presioná <kbd>Espacio</kbd> o hacé clic en "Aleatorio"</p>
      </div>
    </div>

    <!-- Variantes de color -->
    <div id="variant-panel" class="variant-panel hidden"></div>

    <!-- Guardar -->
    <div id="save-bar" class="save-bar hidden">
      <div class="save-top">
        <input
          type="text"
          id="palette-name"
          placeholder="Nombre de la paleta…"
          maxlength="50"
        />
        <button id="btn-save" class="btn-save">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none">
            <path
              d="M19 21H5a2 2 0 01-2-2V5a2 2 0 012-2h11l5 5v11a2 2 0 01-2 2z"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"></path>
            <path
              d="M17 21v-8H7v8M7 3v5h8"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"></path>
          </svg>
          Guardar paleta
        </button>
      </div>
      <div class="save-tags">
        <span class="tags-label">Etiquetas</span>
        <div id="tags-box" class="tags-box">
          <input
            type="text"
            id="tag-input"
            class="tag-input"
            placeholder="Escribí una etiqueta y presioná Enter…"
            maxlength="30"
          />
        </div>
      </div>
    </div>
  </div>
</AppLayout>

<script>
  import { generatePalette, enrichWithNames, getColorName, hexToHsl, hslToHex } from "../../lib/colors";
  import type { GeneratedColor, HarmonyType } from "../../lib/colors";

  let currentColors: GeneratedColor[] = [];
  let isLoading = false;

  const harmonyEl = document.getElementById("harmony") as HTMLSelectElement;
  const pickerEl = document.getElementById(
    "base-color-picker",
  ) as HTMLInputElement;
  const hexInputEl = document.getElementById(
    "base-color-hex",
  ) as HTMLInputElement;
  const countEl = document.getElementById("count") as HTMLInputElement;
  const countLabel = document.getElementById("count-label")!;
  const btnRandom = document.getElementById("btn-random")!;
  const btnFromBase = document.getElementById("btn-from-base")!;
  const paletteView = document.getElementById("palette-view")!;
  const saveBar = document.getElementById("save-bar")!;
  const nameInput = document.getElementById("palette-name") as HTMLInputElement;
  const btnSave = document.getElementById("btn-save")!;
  const variantPanel = document.getElementById("variant-panel")!;
  const tagsBox    = document.getElementById("tags-box")!;
  const tagInput   = document.getElementById("tag-input") as HTMLInputElement;

  let currentTags: string[] = [];

  function renderTags() {
    // Borra todos los chips existentes (no el input)
    tagsBox.querySelectorAll(".tag-chip").forEach(el => el.remove());
    currentTags.forEach(tag => {
      const chip = document.createElement("span");
      chip.className = "tag-chip";
      chip.textContent = tag;
      const rm = document.createElement("button");
      rm.className = "tag-chip-remove";
      rm.type = "button";
      rm.textContent = "×";
      rm.addEventListener("click", () => {
        currentTags = currentTags.filter(t => t !== tag);
        renderTags();
      });
      chip.appendChild(rm);
      tagsBox.insertBefore(chip, tagInput);
    });
  }

  tagInput.addEventListener("keydown", (e) => {
    if (e.key === "Enter" || e.key === ",") {
      e.preventDefault();
      const val = tagInput.value.trim().replace(/,/g, "");
      if (val && !currentTags.includes(val) && currentTags.length < 8) {
        currentTags.push(val);
        renderTags();
      }
      tagInput.value = "";
    } else if (e.key === "Backspace" && tagInput.value === "" && currentTags.length) {
      currentTags.pop();
      renderTags();
    }
  });

  // Hacer clic en el box enfoca el input
  tagsBox.addEventListener("click", () => tagInput.focus());

  // Sync color picker ↔ text
  pickerEl.addEventListener("input", () => {
    hexInputEl.value = pickerEl.value;
  });
  hexInputEl.addEventListener("input", () => {
    if (/^#[0-9a-fA-F]{6}$/.test(hexInputEl.value))
      pickerEl.value = hexInputEl.value;
  });
  countEl.addEventListener("input", () => {
    countLabel.textContent = countEl.value;
  });

  // Regenerar cuando cambia harmonía (si ya hay paleta generada)
  harmonyEl.addEventListener("change", () => {
    if (currentColors.length) generate(false);
  });

  async function generate(random: boolean) {
    if (isLoading) return;
    isLoading = true;

    // Mostrar estado de carga
    paletteView.innerHTML =
      '<div class="loading-state">Generando<span class="dots">...</span></div>';

    const harmony = harmonyEl.value as HarmonyType;
    const count = parseInt(countEl.value);
    const baseHex = random ? undefined : pickerEl.value;

    const raw = generatePalette(harmony, count, baseHex);
    currentColors = await enrichWithNames(raw);

    // Sync picker al color base resultante
    if (currentColors.length > 0) {
      pickerEl.value = currentColors[0].hex;
      hexInputEl.value = currentColors[0].hex;
    }

    renderPalette();
    saveBar.classList.remove("hidden");
    isLoading = false;
  }

  function renderPalette() {
    paletteView.innerHTML = "";
    variantPanel.classList.add("hidden");

    const strip = document.createElement("div");
    strip.className = "color-strip";

    currentColors.forEach((c, i) => {
      const col = document.createElement("div");
      col.className = "color-col";
      col.style.cssText = `background:${c.hex}; animation-delay:${i * 50}ms`;

      // Picker oculto para editar el color
      const picker = document.createElement("input");
      picker.type = "color";
      picker.value = c.hex;
      picker.className = "col-picker";

      const overlay = document.createElement("div");
      overlay.className = "color-overlay";

      const nameDisplay = document.createElement("span");
      nameDisplay.className = "color-name-display";
      nameDisplay.textContent = c.name ?? "";

      const hexDisplay = document.createElement("span");
      hexDisplay.className = "color-hex-display";
      hexDisplay.textContent = c.hex.toUpperCase();

      const copyBtn = document.createElement("button");
      copyBtn.className = "btn-copy-col";
      copyBtn.dataset.hex = c.hex;
      copyBtn.innerHTML = `
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none">
          <rect x="9" y="9" width="13" height="13" rx="2" stroke="currentColor" stroke-width="2"/>
          <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1" stroke="currentColor" stroke-width="2"/>
        </svg>
        <span>Copiar</span>
      `;

      const editBtn = document.createElement("button");
      editBtn.className = "btn-edit-col";
      editBtn.innerHTML = `
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none">
          <path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span>Editar</span>
      `;

      // Preview en vivo mientras se arrastra el picker
      picker.addEventListener("input", () => {
        col.style.background = picker.value;
        hexDisplay.textContent = picker.value.toUpperCase();
      });

      // Commit al cerrar el picker: actualiza datos y busca nombre
      picker.addEventListener("change", async () => {
        const newHex = picker.value;
        currentColors[i] = { ...currentColors[i], hex: newHex };
        col.style.background = newHex;
        hexDisplay.textContent = newHex.toUpperCase();
        copyBtn.dataset.hex = newHex;
        nameDisplay.textContent = "…";
        const name = await getColorName(newHex).catch(() => "");
        currentColors[i].name = name;
        nameDisplay.textContent = name;
      });

      editBtn.addEventListener("click", (e) => {
        e.stopPropagation();
        picker.click();
      });

      col.addEventListener("click", (e) => {
        if ((e.target as HTMLElement).closest(".btn-copy-col, .btn-edit-col, .col-picker")) return;
        showVariants(i);
      });

      overlay.appendChild(nameDisplay);
      overlay.appendChild(hexDisplay);
      overlay.appendChild(copyBtn);
      overlay.appendChild(editBtn);
      col.appendChild(picker);
      col.appendChild(overlay);
      strip.appendChild(col);
    });

    paletteView.appendChild(strip);

    // Bind copy buttons
    strip.querySelectorAll(".btn-copy-col").forEach((btn) => {
      btn.addEventListener("click", () => {
        const hex = (btn as HTMLElement).dataset.hex ?? "";
        navigator.clipboard.writeText(hex);
        const span = btn.querySelector("span")!;
        span.textContent = "✓ Copiado";
        setTimeout(() => (span.textContent = "Copiar"), 1500);
      });
    });
  }

  const VARIANT_LIGHTNESSES = [10, 20, 30, 40, 50, 60, 70, 80, 90];

  function showVariants(index: number) {
    const c = currentColors[index];
    const hsl = hexToHsl(c.hex);
    const closestL = VARIANT_LIGHTNESSES.reduce((a, b) =>
      Math.abs(a - hsl.l) <= Math.abs(b - hsl.l) ? a : b
    );

    variantPanel.innerHTML = "";
    variantPanel.classList.remove("hidden");

    const header = document.createElement("div");
    header.className = "variant-header";

    const label = document.createElement("span");
    label.className = "variant-label";
    label.textContent = `Variantes · ${c.hex.toUpperCase()}`;

    const closeBtn = document.createElement("button");
    closeBtn.className = "variant-close";
    closeBtn.textContent = "×";
    closeBtn.addEventListener("click", () => variantPanel.classList.add("hidden"));

    header.appendChild(label);
    header.appendChild(closeBtn);
    variantPanel.appendChild(header);

    const swatches = document.createElement("div");
    swatches.className = "variant-swatches";

    VARIANT_LIGHTNESSES.forEach((l) => {
      const hex = hslToHex({ h: hsl.h, s: hsl.s, l });
      const btn = document.createElement("button");
      btn.className = "variant-swatch" + (l === closestL ? " active" : "");
      btn.style.background = hex;
      btn.title = hex.toUpperCase();

      btn.addEventListener("click", async () => {
        swatches.querySelectorAll(".variant-swatch").forEach((s) => s.classList.remove("active"));
        btn.classList.add("active");
        label.textContent = `Variantes · ${hex.toUpperCase()}`;
        await applyVariant(index, hex);
      });

      swatches.appendChild(btn);
    });

    variantPanel.appendChild(swatches);
  }

  async function applyVariant(index: number, hex: string) {
    const strip = document.querySelector(".color-strip");
    if (!strip) return;
    const col = strip.querySelectorAll(".color-col")[index] as HTMLElement | undefined;
    if (!col) return;

    currentColors[index] = { ...currentColors[index], hex, name: null };
    col.style.background = hex;

    const hexDisplay = col.querySelector(".color-hex-display");
    if (hexDisplay) hexDisplay.textContent = hex.toUpperCase();

    const copyBtn = col.querySelector<HTMLElement>(".btn-copy-col");
    if (copyBtn) copyBtn.dataset.hex = hex;

    const picker = col.querySelector<HTMLInputElement>(".col-picker");
    if (picker) picker.value = hex;

    const nameDisplay = col.querySelector(".color-name-display");
    if (nameDisplay) nameDisplay.textContent = "…";

    const name = await getColorName(hex).catch(() => "");
    currentColors[index].name = name;
    if (nameDisplay) nameDisplay.textContent = name;
  }

  btnRandom.addEventListener("click", () => generate(true));
  btnFromBase.addEventListener("click", () => generate(false));

  // Barra espaciadora = generar
  document.addEventListener("keydown", (e) => {
    if (e.code === "Space" && document.activeElement?.tagName !== "INPUT") {
      e.preventDefault();
      generate(true);
    }
  });

  // Guardar
  btnSave.addEventListener("click", async () => {
    const name = nameInput.value.trim();
    if (!name) {
      nameInput.focus();
      nameInput.classList.add("shake");
      setTimeout(() => nameInput.classList.remove("shake"), 400);
      return;
    }
    if (!currentColors.length) return;

    btnSave.setAttribute("disabled", "true");
    btnSave.innerHTML = "⏳ Guardando…";

    const res = await fetch("/api/palettes/create", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        name,
        tags: currentTags,
        colors: currentColors.map((c, i) => ({
          hex: c.hex,
          name: c.name,
          position: i,
        })),
      }),
    });

    if (res.ok) {
      window.location.href = "/dashboard";
    } else {
      btnSave.removeAttribute("disabled");
      btnSave.textContent = "Error — reintentar";
    }
  });
</script>

<style>
  .generator-page {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }

  .gen-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
  }
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    color: var(--text-3);
    text-decoration: none;
    font-size: 0.85rem;
    transition: color 0.15s;
    margin-bottom: 0.4rem;
  }
  .back-link:hover {
    color: var(--text);
  }
  h1 {
    font-size: 2rem;
    font-weight: 800;
    letter-spacing: -0.04em;
  }

  .spacebar-hint {
    font-size: 0.8rem;
    color: var(--text-3);
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }
  kbd {
    padding: 0.2rem 0.5rem;
    background: var(--bg-3);
    border: 1px solid var(--border-2);
    border-radius: 5px;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-2);
  }

  /* Controls */
  .controls-bar {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    gap: 1.25rem;
    padding: 1.25rem 1.5rem;
    background: var(--bg-2);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
  }
  .control-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  label {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--text-3);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  select {
    background: var(--bg-3);
    border: 1px solid var(--border);
    border-radius: 7px;
    color: var(--text);
    padding: 0.5rem 0.75rem;
    font-family: var(--font-display);
    font-size: 0.875rem;
    cursor: pointer;
    transition: border-color 0.15s;
  }
  select:focus {
    outline: none;
    border-color: var(--accent);
  }
  .color-input-row {
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }
  input[type="color"] {
    width: 38px;
    height: 34px;
    border: 1px solid var(--border);
    border-radius: 7px;
    padding: 2px;
    background: var(--bg-3);
    cursor: pointer;
  }
  input[type="text"] {
    width: 90px;
    background: var(--bg-3);
    border: 1px solid var(--border);
    border-radius: 7px;
    padding: 0.5rem 0.6rem;
    color: var(--text);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    transition: border-color 0.15s;
  }
  input[type="text"]:focus {
    outline: none;
    border-color: var(--accent);
  }
  input[type="range"] {
    width: 110px;
    accent-color: var(--accent);
    cursor: pointer;
  }
  .controls-actions {
    display: flex;
    gap: 0.6rem;
    align-self: flex-end;
  }
  .btn-secondary {
    padding: 0.5rem 1rem;
    background: var(--bg-3);
    border: 1px solid var(--border);
    border-radius: 8px;
    color: var(--text-2);
    font-family: var(--font-display);
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    transition:
      border-color 0.15s,
      color 0.15s,
      transform 0.1s;
  }
  .btn-secondary:hover {
    border-color: var(--accent);
    color: var(--accent);
    transform: translateY(-1px);
  }

  /* ── Palette view ── */
  .palette-view {
    height: 320px;
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--border);
    background: var(--bg-2);
  }

  .palette-placeholder {
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    color: var(--text-3);
  }
  .placeholder-icon {
    font-size: 2.5rem;
    color: var(--border-2);
  }
  .palette-placeholder p {
    font-size: 0.875rem;
  }

  .loading-state {
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-mono);
    color: var(--text-3);
    font-size: 0.9rem;
    animation: pulse 1s infinite;
  }
  @keyframes pulse {
    0%,
    100% {
      opacity: 0.4;
    }
    50% {
      opacity: 1;
    }
  }

  /* ── Color strip — ÚNICO bloque, sin duplicados ── */
  /* ── Color strip — fuera del scope de Astro porque los genera JS ── */
  :global(.color-strip) {
    display: flex;
    height: 100%;
  }

  :global(.color-col) {
    flex: 1;
    position: relative;
    transition: flex 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    animation: slideIn 0.35s ease both;
    cursor: default;
  }
  :global(.color-col:hover) { flex: 1.8; }

  :global(.color-overlay) {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 1.25rem 1rem;
    background: linear-gradient(to top, rgba(0,0,0,0.55), transparent);
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    opacity: 0;
    transition: opacity 0.2s;
  }
  :global(.color-col:hover .color-overlay) { opacity: 1; }

  :global(.color-name-display) {
    font-size: 0.7rem;
    color: rgba(255,255,255,0.7);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  :global(.color-hex-display) {
    font-family: var(--font-mono);
    font-weight: 500;
    font-size: 0.95rem;
    color: white;
  }

  :global(.btn-copy-col) {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    margin-top: 0.4rem;
    padding: 0.35rem 0.7rem;
    background: rgba(255,255,255,0.15);
    border: 1px solid rgba(255,255,255,0.25);
    border-radius: 6px;
    color: white;
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 600;
    cursor: pointer;
    backdrop-filter: blur(4px);
    transition: background 0.15s;
    width: fit-content;
  }
  :global(.btn-copy-col:hover) { background: rgba(255,255,255,0.25); }

  :global(.col-picker) {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
    pointer-events: none;
  }

  :global(.btn-edit-col) {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    margin-top: 0.2rem;
    padding: 0.35rem 0.7rem;
    background: rgba(255,255,255,0.15);
    border: 1px solid rgba(255,255,255,0.25);
    border-radius: 6px;
    color: white;
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 600;
    cursor: pointer;
    backdrop-filter: blur(4px);
    transition: background 0.15s;
    width: fit-content;
  }
  :global(.btn-edit-col:hover) { background: rgba(255,255,255,0.25); }

  /* ── Variant panel ── */
  /* .variant-panel está en el HTML estático → scope de Astro funciona */
  .variant-panel {
    padding: 1rem 1.5rem;
    background: var(--bg-2);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    animation: fadeUp 0.2s ease;
  }
  .variant-panel.hidden { display: none; }

  /* Los hijos se crean con JS → necesitan :global() para recibir estilos */
  :global(.variant-header) {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.85rem;
  }
  :global(.variant-label) {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--text-3);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-family: var(--font-mono);
  }
  :global(.variant-close) {
    background: none;
    border: none;
    color: var(--text-3);
    cursor: pointer;
    font-size: 1.25rem;
