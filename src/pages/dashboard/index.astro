---
import AppLayout from '../../layouts/AppLayout.astro';
import PaletteCard from '../../components/PaletteCard.astro';
import { getSessionFromCookies } from '../../lib/supabase';
import { getUserPalettes } from '../../lib/palettes';

const cookieHeader = Astro.request.headers.get('cookie') ?? '';
const cookieMap = Object.fromEntries(
  cookieHeader.split(';').map(c => {
    const [k, ...v] = c.trim().split('=');
    return [k, v.join('=')];
  })
);
const session = await getSessionFromCookies(cookieMap);
if (!session) return Astro.redirect('/login');
const palettes = await getUserPalettes(session.user.id);
---

<AppLayout title="Mis paletas">
  <div class="dashboard">
    <div class="page-header">
      <div>
        <h1>Mis paletas</h1>
        <p class="page-subtitle">
          {palettes.length === 0
            ? 'Todavía no creaste ninguna.'
            : `${palettes.length} paleta${palettes.length !== 1 ? 's' : ''} guardada${palettes.length !== 1 ? 's' : ''}`
          }
        </p>
      </div>
      <a href="/dashboard/new" class="btn-cta">+ Nueva paleta</a>
    </div>

    {palettes.length === 0 ? (
      <div class="empty-state">
        <div class="empty-icon">◈</div>
        <h2>Tu estudio está vacío</h2>
        <p>Creá tu primera paleta y empezá a construir tu colección.</p>
        <a href="/dashboard/new" class="btn-cta">Crear paleta</a>
      </div>
    ) : (
      <div class="palettes-grid" id="palettes-grid">
        {palettes.map((p, i) => (
          <div style={`--delay: ${i * 60}ms`}>
            <PaletteCard palette={p} />
          </div>
        ))}
      </div>
    )}
  </div>
</AppLayout>

<script>
  document.getElementById('palettes-grid')?.addEventListener('click', async (e) => {
    const btn = (e.target as HTMLElement).closest('.btn-delete') as HTMLElement | null;
    if (!btn) return;
    const id = btn.dataset.id;
    if (!id || !confirm('¿Eliminar esta paleta?')) return;

    const res = await fetch('/api/palettes/delete', {
      method: 'DELETE',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id }),
    });

    if (res.ok) {
      const card = btn.closest('[style*="--delay"]') as HTMLElement | null;
      if (card) {
        card.style.transition = 'opacity 0.2s, transform 0.2s';
        card.style.opacity = '0';
        card.style.transform = 'scale(0.95)';
        setTimeout(() => card.remove(), 200);
      }
    } else {
      alert('Error al eliminar la paleta');
    }
  });
</script>

<style>
  .page-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 2.5rem;
    gap: 1rem;
  }
  h1 {
    font-size: 2rem;
    font-weight: 800;
    letter-spacing: -0.04em;
  }
  .page-subtitle {
    color: var(--text-3);
    font-size: 0.875rem;
    margin-top: 0.25rem;
    font-family: var(--font-mono);
  }

  .btn-cta {
    padding: 0.6rem 1.25rem;
    background: var(--accent);
    color: #0e0e11;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.875rem;
    border-radius: 8px;
    text-decoration: none;
    white-space: nowrap;
    transition: background 0.15s, transform 0.1s;
    flex-shrink: 0;
  }
  .btn-cta:hover { background: var(--accent-dim); transform: translateY(-1px); }

  .palettes-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1.25rem;
  }
  .palettes-grid > div {
    animation: fadeUp 0.4s ease both;
    animation-delay: var(--delay, 0ms);
  }
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 6rem 2rem;
    gap: 0.75rem;
    animation: fadeUp 0.5s ease both;
  }
  .empty-icon {
    font-size: 3rem;
    color: var(--border-2);
    margin-bottom: 0.5rem;
  }
  .empty-state h2 {
    font-size: 1.4rem;
    font-weight: 700;
    letter-spacing: -0.03em;
  }
  .empty-state p {
    color: var(--text-3);
    font-size: 0.9rem;
    max-width: 300px;
    margin-bottom: 0.5rem;
  }
</style>