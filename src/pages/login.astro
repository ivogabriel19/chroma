---
import BaseLayout from '../layouts/BaseLayout.astro';

const registered = Astro.url.searchParams.get('registered');
const error = Astro.url.searchParams.get('error');
---
<BaseLayout title="Iniciar sesión">
  <div class="auth-container">
    <div class="auth-card">
      <h1>Iniciar sesión</h1>

      {registered && (
        <p class="msg-success">¡Cuenta creada! Ya podés iniciar sesión.</p>
      )}
      {error && (
        <p class="msg-error">{error}</p>
      )}

      <form method="POST" action="/api/auth/login" class="auth-form">
        <label>
          Email
          <input type="email" name="email" required />
        </label>
        <label>
          Contraseña
          <input type="password" name="password" required />
        </label>
        <button type="submit" class="btn-primary">Entrar</button>
      </form>

      <p class="auth-link">
        ¿No tenés cuenta? <a href="/register">Registrate</a>
      </p>
    </div>
  </div>
</BaseLayout>

<style>
  @import '../styles/auth.css';
</style>