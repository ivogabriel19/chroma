---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getSessionFromCookies } from '../lib/supabase';
import { getAllPalettes } from '../lib/palettes';

import { Image } from 'astro:assets';
import logo from '../assets/logo-256.png';

const cookieHeader = Astro.request.headers.get('cookie') ?? '';
const cookieMap = Object.fromEntries(
  cookieHeader.split(';').map(c => {
    const [k, ...v] = c.trim().split('=');
    return [k, v.join('=')];
  })
);

const session = await getSessionFromCookies(cookieMap);
const isLoggedIn = session !== null;

let allPalettes: Awaited<ReturnType<typeof getAllPalettes>> = [];
try {
  allPalettes = await getAllPalettes();
} catch {}

// Serializar datos para el cliente
const palettesData = allPalettes.map(p => ({
  id: p.id,
  name: p.name,
  creator: p.user_id.substring(0, 8),
  tags: p.tags ?? [],
  colors: (p.colors ?? [])
    .sort((a, b) => a.position - b.position)
    .map(c => ({ hex: c.hex, name: c.name ?? '' })),
}));

// Tags únicos para el filtro (orden alfabético)
const allTags = [...new Set(allPalettes.flatMap(p => p.tags ?? []))].sort();
---

<BaseLayout title="Catálogo — Paletta">
  <div class="catalog-shell">

    <!-- Header -->
    <header class="catalog-header">
      <a href="/dashboard" class="logo">
        <span class="logo-mark">
          <Image src={logo} alt="">
        </span>
        <span class="logo-text">Chroma</span>
      </a>
      <nav class="header-nav">
        {isLoggedIn ? (
          <>
            <a href="/dashboard" class="nav-link">Dashboard</a>
            <span class="user-email">{session!.user.email}</span>
            <form method="POST" action="/api/auth/logout">
              <button type="submit" class="btn-logout">Salir</button>
            </form>
          </>
        ) : (
          <a href="/login" class="btn-login">Iniciar sesión</a>
        )}
      </nav>
    </header>

    <!-- Contenido -->
    <main class="catalog-main">
      <div class="catalog-page-header">
        <h1>Catálogo</h1>
        <p class="subtitle">{allPalettes.length} paleta{allPalettes.length !== 1 ? 's' : ''} de la comunidad</p>
      </div>

      <!-- Barra de búsqueda -->
      <div class="search-bar">
        <svg class="search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none">
          <circle cx="11" cy="11" r="8" stroke="currentColor" stroke-width="2"/>
          <path d="m21 21-4.35-4.35" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
        <input
          id="search-input"
          type="text"
          class="search-input"
          placeholder="Buscar paletas por nombre o etiqueta…"
          autocomplete="off"
        />
        <button id="search-clear" class="search-clear hidden" aria-label="Limpiar búsqueda">×</button>
      </div>

      {allTags.length > 0 && (
        <div class="filter-bar" id="filter-bar">
          <span class="filter-label">Etiquetas</span>
          {allTags.map(tag => (
            <button class="filter-chip" data-tag={tag}>{tag}</button>
          ))}
          <button class="filter-clear hidden" id="filter-clear">Limpiar</button>
        </div>
      )}

      {allPalettes.length === 0 ? (
        <div class="empty-state">
          <span class="empty-icon">◈</span>
          <p>Todavía no hay paletas públicas.</p>
        </div>
      ) : (
        <div class="palette-grid" id="palette-grid">
          {allPalettes.map(p => {
            const colors = (p.colors ?? []).sort((a, b) => a.position - b.position);
            const tags = p.tags ?? [];
            return (
              <button
                class="palette-card"
                data-palette-id={p.id}
                data-tags={JSON.stringify(tags)}
                aria-label={`Ver paleta ${p.name}`}
              >
                <div class="card-strip">
                  {colors.map(c => (
                    <div class="card-swatch" style={`background:${c.hex}`} />
                  ))}
                </div>
                <div class="card-info">
                  <span class="card-name">{p.name}</span>
                  <span class="card-creator">@{p.user_id.substring(0, 8)}</span>
                </div>
                {tags.length > 0 && (
                  <div class="card-tags">
                    {tags.map(tag => (
                      <span class="card-tag">{tag}</span>
                    ))}
                  </div>
                )}
              </button>
            );
          })}
        </div>
      )}
    </main>

    <!-- Modal -->
    <div id="modal-backdrop" class="modal-backdrop hidden" role="dialog" aria-modal="true">
      <div class="modal" id="modal">
        <button id="modal-close" class="modal-close" aria-label="Cerrar">×</button>

        <div id="modal-strip" class="modal-strip"></div>

        <div class="modal-body">
          <div class="modal-meta">
            <h2 id="modal-name" class="modal-name"></h2>
            <span id="modal-creator" class="modal-creator"></span>
            <div id="modal-tags" class="modal-tags"></div>
          </div>

          <div id="modal-colors" class="modal-colors"></div>

          <div class="modal-actions">
            {isLoggedIn ? (
              <button id="modal-copy-btn" class="btn-copy-palette">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none">
                  <rect x="9" y="9" width="13" height="13" rx="2" stroke="currentColor" stroke-width="2"/>
                  <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1" stroke="currentColor" stroke-width="2"/>
                </svg>
                Copiar al dashboard
              </button>
            ) : (
              <div class="modal-login-cta">
                <span class="modal-login-hint">Iniciá sesión para guardar paletas en tu dashboard</span>
                <a href="/login" class="btn-login-cta">Iniciar sesión</a>
              </div>
            )}
          </div>
        </div>
      </div>
    </div>

  </div>
</BaseLayout>

<script define:vars={{ palettesData, isLoggedIn }}>
  const backdrop = document.getElementById('modal-backdrop');
  const modalName = document.getElementById('modal-name');
  const modalCreator = document.getElementById('modal-creator');
  const modalTagsEl = document.getElementById('modal-tags');
  const modalStrip = document.getElementById('modal-strip');
  const modalColors = document.getElementById('modal-colors');
  const modalCopyBtn = document.getElementById('modal-copy-btn');
  const modalClose = document.getElementById('modal-close');

  // Indexar por id para acceso rápido
  const palettesMap = new Map(palettesData.map(p => [p.id, p]));

  let activePaletteId = null;

  // ── Búsqueda y filtro ─────────────────────────────────────
  const activeTags = new Set();
  let searchQuery = '';

  const filterChips = document.querySelectorAll('.filter-chip');
  const filterClear = document.getElementById('filter-clear');
  const cards = document.querySelectorAll('.palette-card');
  const searchInput = document.getElementById('search-input');
  const searchClear = document.getElementById('search-clear');

  function applyFilter() {
    const q = searchQuery.toLowerCase().trim();

    cards.forEach(card => {
      const p = palettesMap.get(card.dataset.paletteId);
      if (!p) return;

      // Filtro por texto: nombre o cualquier etiqueta
      const matchesText = q === ''
        || p.name.toLowerCase().includes(q)
        || (p.tags ?? []).some(t => t.toLowerCase().includes(q));

      // Filtro por chips activos (OR: basta con que tenga una)
      const matchesTags = activeTags.size === 0
        || [...activeTags].some(t => (p.tags ?? []).includes(t));

      card.style.display = matchesText && matchesTags ? '' : 'none';
    });

    if (filterClear) {
      filterClear.classList.toggle('hidden', activeTags.size === 0);
    }
    if (searchClear) {
      searchClear.classList.toggle('hidden', searchQuery === '');
    }
  }

  // Búsqueda por texto
  if (searchInput) {
    searchInput.addEventListener('input', () => {
      searchQuery = searchInput.value;
      applyFilter();
    });
  }

  if (searchClear) {
    searchClear.addEventListener('click', () => {
      searchQuery = '';
      searchInput.value = '';
      applyFilter();
    });
  }

  // Chips de etiquetas
  filterChips.forEach(chip => {
    chip.addEventListener('click', () => {
      const tag = chip.dataset.tag;
      if (activeTags.has(tag)) {
        activeTags.delete(tag);
        chip.classList.remove('active');
      } else {
        activeTags.add(tag);
        chip.classList.add('active');
      }
      applyFilter();
    });
  });

  if (filterClear) {
    filterClear.addEventListener('click', () => {
      activeTags.clear();
      filterChips.forEach(c => c.classList.remove('active'));
      applyFilter();
    });
  }

  const CLIPBOARD_SVG = `<svg width="14" height="14" viewBox="0 0 24 24" fill="none"><rect x="9" y="9" width="13" height="13" rx="2" stroke="currentColor" stroke-width="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1" stroke="currentColor" stroke-width="2"/></svg>`;
  const CHECK_SVG    = `<svg width="14" height="14" viewBox="0 0 24 24" fill="none"><polyline points="20 6 9 17 4 12" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`;

  // Abrir modal al hacer click en una card
  document.querySelectorAll('.palette-card').forEach(card => {
    card.addEventListener('click', () => {
      const id = card.dataset.paletteId;
      openModal(id);
    });
  });

  function openModal(id) {
    const p = palettesMap.get(id);
    if (!p) return;

    activePaletteId = id;

    // Nombre, creador y tags
    modalName.textContent = p.name;
    modalCreator.textContent = '@' + p.creator;

    // Tags del modal
    if (modalTagsEl) {
      modalTagsEl.innerHTML = '';
      (p.tags ?? []).forEach(tag => {
        const chip = document.createElement('span');
        chip.className = 'modal-tag-chip';
        chip.textContent = tag;
        modalTagsEl.appendChild(chip);
      });
    }

    // Franja de colores (con hex label al hover)
    modalStrip.innerHTML = '';
    p.colors.forEach(c => {
      const col = document.createElement('div');
      col.className = 'modal-strip-col';
      col.style.background = c.hex;

      const label = document.createElement('span');
      label.className = 'modal-strip-label';
      label.textContent = c.hex.toUpperCase();
      col.appendChild(label);

      modalStrip.appendChild(col);
    });

    // Lista de colores
    modalColors.innerHTML = '';
    p.colors.forEach(c => {
      const row = document.createElement('div');
      row.className = 'modal-color-row';

      const dot = document.createElement('div');
      dot.className = 'modal-color-dot';
      dot.style.background = c.hex;

      const info = document.createElement('div');
      info.className = 'modal-color-info';

      const hex = document.createElement('span');
      hex.className = 'modal-color-hex';
      hex.textContent = c.hex.toUpperCase();

      const name = document.createElement('span');
      name.className = 'modal-color-name';
      name.textContent = c.name;

      info.appendChild(hex);
      info.appendChild(name);

      const copyHex = document.createElement('button');
      copyHex.className = 'modal-copy-hex';
      copyHex.title = 'Copiar HEX';
      copyHex.innerHTML = CLIPBOARD_SVG;
      copyHex.addEventListener('click', () => {
        navigator.clipboard.writeText(c.hex);
        copyHex.innerHTML = CHECK_SVG;
        setTimeout(() => { copyHex.innerHTML = CLIPBOARD_SVG; }, 1500);
      });

      row.appendChild(dot);
      row.appendChild(info);
      row.appendChild(copyHex);
      modalColors.appendChild(row);
    });

    // Reset botón de copiar
    if (modalCopyBtn) {
      modalCopyBtn.textContent = '';
      modalCopyBtn.innerHTML = `
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none">
          <rect x="9" y="9" width="13" height="13" rx="2" stroke="currentColor" stroke-width="2"/>
          <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1" stroke="currentColor" stroke-width="2"/>
        </svg>
        Copiar al dashboard
      `;
      modalCopyBtn.disabled = false;
    }

    backdrop.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    backdrop.classList.add('hidden');
    document.body.style.overflow = '';
    activePaletteId = null;
  }

  // Cerrar con X
  modalClose.addEventListener('click', closeModal);

  // Cerrar al hacer click fuera del modal
  backdrop.addEventListener('click', e => {
    if (e.target === backdrop) closeModal();
  });

  // Cerrar con Escape
  document.addEventListener('keydown', e => {
    if (e.key === 'Escape') closeModal();
  });

  // Copiar paleta al dashboard
  if (modalCopyBtn) {
    modalCopyBtn.addEventListener('click', async () => {
      if (!activePaletteId) return;

      modalCopyBtn.disabled = true;
      modalCopyBtn.textContent = 'Copiando…';

      try {
        const res = await fetch('/api/palettes/copy', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ paletteId: activePaletteId }),
        });

        if (res.ok) {
          modalCopyBtn.textContent = '✓ Copiada';
          setTimeout(() => {
            window.location.href = '/dashboard';
          }, 800);
        } else if (res.status === 401) {
          window.location.href = '/login';
        } else {
          modalCopyBtn.textContent = 'Error — reintentar';
          modalCopyBtn.disabled = false;
        }
      } catch {
        modalCopyBtn.textContent = 'Error — reintentar';
        modalCopyBtn.disabled = false;
      }
    });
  }
</script>

<style>

    .logo-mark {
    font-size: 1.3rem;
    color: var(--accent);
    line-height: 1;

    & > img {
      height: 2rem;
      width: 2rem;
    }
  }
  /* ── Shell ── */
  .catalog-shell {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    background: var(--bg);
  }

  /* ── Header ── */
  .catalog-header {
    position: sticky;
    top: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 2rem;
    height: 56px;
    background: rgba(250,250,250,0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }
  .logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    color: var(--text);
  }
  .logo-mark { font-size: 1.3rem; color: var(--accent-2); line-height: 1; }
  .logo-text { font-size: 1.1rem; font-weight: 800; letter-spacing: -0.03em; }

  .header-nav {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }
  .nav-link {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text-2);
    text-decoration: none;
    transition: color 0.15s;
  }
  .nav-link:hover { color: var(--text); }
  .user-email {
    font-size: 0.8rem;
    color: var(--text-3);
    font-family: var(--font-mono);
    display: none;
  }
  @media (min-width: 640px) { .user-email { display: block; } }
  .btn-logout {
    background: none;
    border: 1px solid var(--border-2);
    color: var(--text-2);
    padding: 0.4rem 0.85rem;
    border-radius: 7px;
    font-family: var(--font-display);
    font-size: 0.82rem;
    cursor: pointer;
    transition: border-color 0.15s, color 0.15s;
  }
  .btn-logout:hover { border-color: var(--danger); color: var(--danger); }
  .btn-login {
    padding: 0.45rem 1rem;
    background: var(--accent);
    color: #0e0e11;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.85rem;
    border-radius: 8px;
    text-decoration: none;
    transition: background 0.15s;
  }
  .btn-login:hover { background: var(--accent-dim); }

  /* ── Main ── */
  .catalog-main {
    flex: 1;
    max-width: 1200px;
    width: 100%;
    margin: 0 auto;
    padding: 2.5rem 2rem;
  }
  .catalog-page-header {
    margin-bottom: 2rem;
  }
  h1 {
    font-size: 2rem;
    font-weight: 800;
    letter-spacing: -0.04em;
    margin: 0 0 0.25rem;
  }
  .subtitle {
    font-size: 0.875rem;
    color: var(--text-3);
    margin: 0;
    font-family: var(--font-mono);
  }

  /* ── Grid ── */
  .palette-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 1rem;
  }

  /* ── Card ── */
  .palette-card {
    background: var(--bg-2);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    cursor: pointer;
    text-align: left;
    padding: 0;
    transition: border-color 0.15s, transform 0.15s, box-shadow 0.15s;
    width: 100%;
  }
  .palette-card:hover {
    border-color: var(--border-2);
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.06);
  }

  .card-strip {
    height: 80px;
    display: flex;
  }
  .card-swatch { flex: 1; }

  .card-info {
    padding: 0.75rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .card-name {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .card-creator {
    font-size: 0.75rem;
    color: var(--text-3);
    font-family: var(--font-mono);
  }

  /* ── Search bar ── */
  .search-bar {
    position: relative;
    display: flex;
    align-items: center;
    margin-bottom: 1rem;
  }
  .search-icon {
    position: absolute;
    left: 0.9rem;
    color: var(--text-3);
    pointer-events: none;
    flex-shrink: 0;
  }
  .search-input {
    width: 100%;
    padding: 0.65rem 2.5rem 0.65rem 2.5rem;
    font-family: var(--font-display);
    font-size: 0.9rem;
    background: var(--bg-2);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    color: var(--text);
    outline: none;
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  .search-input::placeholder { color: var(--text-3); }
  .search-input:focus {
    border-color: var(--accent-2);
    box-shadow: 0 0 0 3px rgba(var(--accent-2-rgb, 120,120,200), 0.12);
  }
  .search-clear {
    position: absolute;
    right: 0.75rem;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: var(--bg-3);
    border: 1px solid var(--border-2);
    color: var(--text-3);
    font-size: 1rem;
    line-height: 1;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.15s, border-color 0.15s;
  }
  .search-clear:hover { color: var(--danger); border-color: var(--danger); }
  .search-clear.hidden { display: none; }

  /* ── Filter bar ── */
  .filter-bar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }
  .filter-label {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--text-3);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-right: 0.25rem;
  }
  .filter-chip {
    padding: 0.3rem 0.75rem;
    font-family: var(--font-display);
    font-size: 0.78rem;
    font-weight: 600;
    border: 1px solid var(--border-2);
    border-radius: 999px;
    background: var(--bg-2);
    color: var(--text-2);
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s, color 0.15s;
  }
  .filter-chip:hover { border-color: var(--accent-2); color: var(--accent-2); }
  .filter-chip.active {
    background: var(--accent-2);
    border-color: var(--accent-2);
    color: #fff;
  }
  .filter-clear {
    padding: 0.3rem 0.75rem;
    font-family: var(--font-display);
    font-size: 0.78rem;
    font-weight: 600;
    border: 1px solid var(--border-2);
    border-radius: 999px;
    background: transparent;
    color: var(--text-3);
    cursor: pointer;
    transition: color 0.15s, border-color 0.15s;
  }
  .filter-clear:hover { color: var(--danger); border-color: var(--danger); }
  .filter-clear.hidden { display: none; }

  /* ── Card tags ── */
  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    padding: 0 1rem 0.75rem;
  }
  .card-tag {
    padding: 0.2rem 0.55rem;
    font-size: 0.7rem;
    font-weight: 600;
    border-radius: 999px;
    background: var(--bg-3);
    color: var(--text-3);
    border: 1px solid var(--border);
  }

  /* ── Empty ── */
  .empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    min-height: 300px;
    color: var(--text-3);
  }
  .empty-icon { font-size: 2.5rem; }

  /* ── Modal backdrop ── */
  .modal-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.45);
    backdrop-filter: blur(8px);
    z-index: 500;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
  }
  .modal-backdrop.hidden { display: none; }

  /* ── Modal container ── */
  .modal {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    width: 100%;
    max-width: 600px;
    max-height: 88vh;
    /* flex column: franja fija arriba, body con scroll abajo */
    display: flex;
    flex-direction: column;
    position: relative;
    box-shadow: 0 24px 64px rgba(0,0,0,0.14);
    animation: modalIn 0.22s cubic-bezier(0.34, 1.2, 0.64, 1);
  }
  @keyframes modalIn {
    from { opacity: 0; transform: scale(0.94) translateY(14px); }
    to   { opacity: 1; transform: scale(1)    translateY(0); }
  }

  /* Botón cerrar */
  .modal-close {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    z-index: 10;
    width: 30px;
    height: 30px;
    border-radius: 50%;
    background: rgba(0,0,0,0.3);
    backdrop-filter: blur(4px);
    border: none;
    color: white;
    font-size: 1.1rem;
    line-height: 1;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s;
  }
  .modal-close:hover { background: rgba(0,0,0,0.55); }

  /* Franja de colores — no hace scroll, se queda fija arriba */
  .modal-strip {
